# stage-bridge Agent 配置文件示例
# 复制此文件为 .env 并填写实际值

# ── Consul 连接 ──────────────────────────────────────────────
CONSUL_ADDR=127.0.0.1:8500
CONSUL_TOKEN=

# ── Agent 标识 ───────────────────────────────────────────────
# 全局唯一 ID，用于标识此 Agent 实例
AGENT_ID=translate-agent

# ── 服务配置 ─────────────────────────────────────────────────
# 绑定的微服务名称（开发 Agent 必填）
SERVICE_NAME=translate-extension

# 代码仓库本地路径
REPO_PATH=

# ── 任务配置（可选）──────────────────────────────────────────
# 当前正在执行的需求和任务
# REQ_ID=req-001
# TASK_NAME=implement-api
